# OpenSea API Key (required for OpenSea links)
# Get yours: https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=

# Block Explorer API Keys (optional, for ABI fetch fallback)
ETHERSCAN_KEY=
BASESCAN_KEY=
ARBISCAN_KEY=
POLYGONSCAN_KEY=

# Custom RPC Overrides (optional, defaults use public endpoints)
ETH_RPC=https://ethereum-rpc.publicnode.com
BASE_RPC=https://base-rpc.publicnode.com
